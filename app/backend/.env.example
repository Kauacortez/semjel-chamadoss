# Variáveis de Ambiente — SEMJEL Chamados
# Copie este arquivo para .env e preencha os valores

# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT (Use uma chave longa e aleatória em produção) ─────────────────────────
JWT_SECRET=COLOQUE-AQUI-UMA-CHAVE-SECRETA-LONGA-E-ALEATORIA-DE-32-CARACTERES
JWT_EXPIRES_IN=8h

# ── Banco de Dados PostgreSQL (Neon) ─────────────────────────────────────────
# Copie a "Connection String" do painel do Neon
DATABASE_URL=postgresql://usuario:senha@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── URL do Frontend (para CORS em produção) ───────────────────────────────────
# Coloque a URL gerada pelo Render após o deploy
FRONTEND_URL=https://semjel-chamados.onrender.com
